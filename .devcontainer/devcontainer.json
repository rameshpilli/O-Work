{
  "name": "OpenWork Full Stack (Electron)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "workspace",
  "workspaceFolder": "/workspace",
  "forwardPorts": [
    3005,
    5173,
    6080,
    8788,
    9825
  ],
  "portsAttributes": {
    "5173": { "label": "App (Vite HMR)", "onAutoForward": "silent" },
    "3005": { "label": "Den Web", "onAutoForward": "notify" },
    "6080": { "label": "Desktop App (noVNC)", "onAutoForward": "notify" },
    "8788": { "label": "Den API", "onAutoForward": "silent" },
    "9825": { "label": "CDP Debug", "onAutoForward": "silent" }
  },
  "postCreateCommand": "pnpm install",
  "postStartCommand": ".devcontainer/start-services.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
